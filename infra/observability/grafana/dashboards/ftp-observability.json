{
  "id": null,
  "uid": "framefast-ftp-observability",
  "title": "FrameFast FTP - Observability",
  "tags": ["framefast", "ftp", "observability"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "FTP Upload Rate by Status (events/s)",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(framefast_ftp_uploads_total[5m]))" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "FTP Upload p95 Duration (ms)",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(framefast_ftp_upload_duration_ms_bucket[5m])))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "FTP Upload p95 Size (bytes)",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(framefast_ftp_upload_bytes_bucket[5m])))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "FTP Uploaded Bytes/s by Status",
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(framefast_ftp_upload_bytes_sum[5m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "FTP Logs",
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"framefast-ftp\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "FTP Error Logs",
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"framefast-ftp\", level=\"error\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
