[
  {
    "key": "client-errors-spike",
    "title": "Client errors spike",
    "expr": "sum(rate(framefast_client_errors_total[5m]))",
    "op": "gt",
    "threshold": 0.2,
    "for": "10m",
    "severity": "warning",
    "service": "framefast-clients",
    "summary": "Client error ingest rate is elevated",
    "runbook": "infra/observability/runbooks/client-errors.md",
    "relativeFrom": 600
  },
  {
    "key": "api-error-rate-high",
    "title": "API error ratio high",
    "expr": "sum(rate(framefast_api_errors_total[5m])) / clamp_min(sum(rate(framefast_api_requests_total[5m])), 0.001)",
    "op": "gt",
    "threshold": 0.05,
    "for": "10m",
    "severity": "critical",
    "service": "framefast-api",
    "summary": "API error ratio above 5%",
    "runbook": "infra/observability/runbooks/upload-failure.md",
    "relativeFrom": 600
  },
  {
    "key": "pipeline-success-rate-low",
    "title": "Pipeline success rate low",
    "expr": "100 * sum(rate(framefast_pipeline_consumer_jobs_total{status=\"ok\"}[15m])) / clamp_min(sum(rate(framefast_pipeline_consumer_jobs_total[15m])), 0.001)",
    "op": "lt",
    "threshold": 98,
    "for": "15m",
    "severity": "critical",
    "service": "framefast-pipeline",
    "summary": "Photo pipeline success rate dropped below 98%",
    "runbook": "infra/observability/runbooks/upload-failure.md",
    "relativeFrom": 1800
  },
  {
    "key": "pipeline-latency-p95-high",
    "title": "Pipeline E2E p95 latency high",
    "expr": "histogram_quantile(0.95, sum by (le) (rate(framefast_pipeline_callback_e2e_duration_ms_milliseconds_bucket[15m])))",
    "op": "gt",
    "threshold": 120000,
    "for": "15m",
    "severity": "warning",
    "service": "framefast-pipeline",
    "summary": "Pipeline E2E p95 latency above 120s",
    "runbook": "infra/observability/runbooks/upload-failure.md",
    "relativeFrom": 1800
  },
  {
    "key": "search-success-rate-low",
    "title": "Search success rate low",
    "expr": "100 * sum(rate(framefast_search_e2e_total{status=\"ok\"}[15m])) / clamp_min(sum(rate(framefast_search_e2e_total[15m])), 0.001)",
    "op": "lt",
    "threshold": 97,
    "for": "15m",
    "severity": "critical",
    "service": "framefast-search",
    "summary": "Search success rate dropped below 97%",
    "runbook": "infra/observability/runbooks/search-failure.md",
    "relativeFrom": 1800
  },
  {
    "key": "search-latency-p95-high",
    "title": "Search p95 latency high",
    "expr": "histogram_quantile(0.95, sum by (le) (rate(framefast_search_e2e_duration_ms_milliseconds_bucket[15m])))",
    "op": "gt",
    "threshold": 5000,
    "for": "10m",
    "severity": "warning",
    "service": "framefast-search",
    "summary": "Search p95 latency above 5s",
    "runbook": "infra/observability/runbooks/search-failure.md",
    "relativeFrom": 1200
  },
  {
    "key": "pipeline-failure-rate-high",
    "title": "Pipeline failure ratio high",
    "expr": "sum(rate(framefast_pipeline_consumer_jobs_total{status=\"error\"}[10m])) / clamp_min(sum(rate(framefast_pipeline_consumer_jobs_total[10m])), 0.001)",
    "op": "gt",
    "threshold": 0.1,
    "for": "10m",
    "severity": "critical",
    "service": "framefast-pipeline",
    "summary": "Pipeline failures exceed 10%",
    "runbook": "infra/observability/runbooks/upload-failure.md",
    "relativeFrom": 1200
  },
  {
    "key": "recognition-error-rate-high",
    "title": "Recognition error ratio high",
    "expr": "sum(rate(framefast_recognition_errors_total[10m])) / clamp_min(sum(rate(framefast_recognition_requests_total[10m])), 0.001)",
    "op": "gt",
    "threshold": 0.1,
    "for": "10m",
    "severity": "critical",
    "service": "framefast-recognition",
    "summary": "Recognition errors exceed 10%",
    "runbook": "infra/observability/runbooks/search-failure.md",
    "relativeFrom": 1200
  },
  {
    "key": "recognition-latency-p95-high",
    "title": "Recognition p95 latency high",
    "expr": "histogram_quantile(0.95, sum by (le) (rate(framefast_recognition_inference_latency_ms_milliseconds_bucket[10m])))",
    "op": "gt",
    "threshold": 2500,
    "for": "10m",
    "severity": "warning",
    "service": "framefast-recognition",
    "summary": "Recognition p95 latency above 2.5s",
    "runbook": "infra/observability/runbooks/search-failure.md",
    "relativeFrom": 1200
  }
]
